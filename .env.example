# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings > API in the Supabase dashboard).

# Safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NEVER expose this to the browser. Server-side only. Used to create student
# portal logins and to accept WordPress lead submissions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# A password you make up yourself. Put the same value in your WordPress
# webhook configuration so WordPress can prove it is allowed to submit leads.
LEADS_WEBHOOK_SECRET=choose-a-long-random-value
