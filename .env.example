# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings > API in the Supabase dashboard).

# Safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NEVER expose this to the browser. Server-side only. Used to create student
# portal logins and to accept WordPress lead submissions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# A password you make up yourself. Put the same value in your WordPress
# webhook configuration so WordPress can prove it is allowed to submit leads.
LEADS_WEBHOOK_SECRET=choose-a-long-random-value

# Used to email new students their portal login details on registration.
# Get one from https://resend.com (Dashboard > API Keys).
RESEND_API_KEY=your-resend-api-key

# Sender shown on those emails. Must be on a domain verified in Resend
# (Dashboard > Domains) or delivery will silently only reach your own inbox.
RESEND_FROM_EMAIL="Kunokhanya Training Academy <noreply@your-verified-domain>"

# Moodle LMS integration -- creates a matching Moodle account whenever a
# student is registered here. Set up a dedicated external service + service
# account in Moodle (Site administration > Server > Web services) scoped to
# just core_user_create_users, then generate a token for it.
MOODLE_BASE_URL=https://your-moodle-site.example.com
MOODLE_API_TOKEN=your-moodle-webservice-token
